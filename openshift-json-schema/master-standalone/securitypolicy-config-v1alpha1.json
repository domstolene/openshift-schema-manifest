            "string",
            "null"
          ],
          "pattern": "^[^\\$]{0,800}$"
        },
        "disabled": {
          "description": "Disabled toggles whether or not this policy will be executing and actively firing alerts.",
          "type": [
            "boolean",
            "null"
          ]
