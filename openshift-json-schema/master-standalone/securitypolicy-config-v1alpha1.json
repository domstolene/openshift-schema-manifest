                  "scope": {
                    "type": [
                      "object",
                      "null"
                    ],
                    "properties": {
                      "cluster": {
                        "description": "Cluster is either the name or the ID of the cluster that this scope applies to",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "label": {
                        "type": [
                          "object",
                          "null"
                        ],
