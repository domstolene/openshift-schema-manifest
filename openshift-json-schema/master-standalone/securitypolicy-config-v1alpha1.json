        "enforcementActions": {
          "description": "Enforcement lists the enforcement actions to take when a violation from this policy is identified.  Possible value are UNSET_ENFORCEMENT, SCALE_TO_ZERO_ENFORCEMENT, UNSATISFIABLE_NODE_CONSTRAINT_ENFORCEMENT, KILL_POD_ENFORCEMENT, FAIL_BUILD_ENFORCEMENT, FAIL_KUBE_REQUEST_ENFORCEMENT, FAIL_DEPLOYMENT_CREATE_ENFORCEMENT, and. FAIL_DEPLOYMENT_UPDATE_ENFORCEMENT.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "UNSET_ENFORCEMENT",
              "SCALE_TO_ZERO_ENFORCEMENT",
              "UNSATISFIABLE_NODE_CONSTRAINT_ENFORCEMENT",
              "KILL_POD_ENFORCEMENT",
              "FAIL_BUILD_ENFORCEMENT",
              "FAIL_KUBE_REQUEST_ENFORCEMENT",
              "FAIL_DEPLOYMENT_CREATE_ENFORCEMENT",
              "FAIL_DEPLOYMENT_UPDATE_ENFORCEMENT"
            ]
          }
        },
        "eventSource": {
          "description": "EventSource describes which events should trigger execution of this policy",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "NOT_APPLICABLE",
            "DEPLOYMENT_EVENT",
            "AUDIT_LOG_EVENT"
          ]
        },
        "exclusions": {
          "description": "Exclusions define deployments or images that should be excluded from this policy.",
